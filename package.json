{
  "name": "moodcircle",
  "version": "1.0.0",
  "description": "Group mood tracking REST API",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node -r dotenv/config server.js dotenv_config_path=.env.dev",
    "seed": "node scripts/seed.js",
    "dev:fresh": "node scripts/seed.js && node -r dotenv/config server.js dotenv_config_path=.env.dev"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
