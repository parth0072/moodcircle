PORT=3000
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

# Razorpay
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Email OTP (nodemailer — leave blank to use console/dev mode)
# Gmail: enable 2FA → Google Account → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=MoodCircle <yourapp@gmail.com>

# Firebase — Phone Auth (optional, alternative to email OTP)
# Frontend SDK config (Project Settings → General → Your apps → Web app)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=1:123456789:web:abc123

# Backend Admin SDK (Project Settings → Service accounts → Generate new private key)
# Paste the entire JSON as a single line, or use single quotes to preserve it
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
